<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Cups &amp; Cakes — Home</title>

    <!-- Tailwind CSS v4 (browser build, on-the-fly compiler) -->
    <script src="https://unpkg.com/@tailwindcss/browser@4"></script>

    <!-- Inter font (Medium 500 used for the navbar) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap"
      rel="stylesheet"
    />

    <!--
      Tailwind v4 theme tokens — only reusable design tokens live here.
      Colors, font, and Figma MCP asset URLs become Tailwind utilities
      (e.g. `text-brand-blue`, `bg-cups-icon`, `font-sans`).
      No fixed-pixel layout tokens — sizing is fluid via clamp() / Tailwind
      spacing scale on each element.
    -->
    <style type="text/tailwindcss">
      @theme {
        /* Brand palette */
        --color-brand-blue: #87cefa;
        --color-brand-blue-dark: #4aa6dc;
        --color-brand-pink: #eb9cf9;
        --color-brand-border: #a0a0a0;

        /* Typography */
        --font-sans: "Inter", system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;

        /* Figma MCP asset URLs (signed, ~7-day expiry) */
        --background-image-cups-icon: url("https://www.figma.com/api/mcp/asset/ed5742dc-b3d8-478a-809d-24818530b4bb");
        --background-image-heart-group: url("https://www.figma.com/api/mcp/asset/8a7393a4-04a3-4b0c-b250-b5eada5df08d");
        --background-image-cart-icon: url("https://www.figma.com/api/mcp/asset/139e7e9c-4279-47b0-a7e1-e96a042865c8");

        /* Hero (Figma 3311:1437)
           NOTE: The Figma MCP returns two related assets per masked image:
           a small SVG (the mask/placeholder, usually a few hundred bytes)
           and the real photographic asset (multi-MB JPG/PNG). In the React
           reference, the placeholder is used for `maskImage` and the real
           asset for `<img src>`. Always pick the latter for `background-image`,
           otherwise the hero looks empty (300×150 grey SVG placeholder). */
        --background-image-hero-cupcakes: url("https://www.figma.com/api/mcp/asset/d63c95c8-afa3-4115-abed-b15a9d669478");
        --background-image-hero-scroll: url("https://www.figma.com/api/mcp/asset/70f420a3-ac95-471b-8e71-95869fcb6a45");
        --background-image-hero-logo: url("https://www.figma.com/api/mcp/asset/9de14cc6-0e5b-47cf-a7af-9238752814a7");

        /* Cupcake-flavor icon (Figma 3311:1573-1605, Groups 22-30).
           Figma exports nine separate groups but they're all the same
           cupcake glyph visually, so we register one asset and reuse it. */
        --background-image-flavor: url("https://www.figma.com/api/mcp/asset/c353688f-21b1-44dd-bd10-2af4da651396");
      }

      /*
        Navbar utilities — pure Tailwind primitives, no math.
        Sizes use Tailwind's type scale, picked to land within a few px of
        Figma at desktop while scaling down via responsive breakpoints.
        Figma reference: nav text 28px ≈ text-3xl (30px) at xl; logo 46px
        ≈ text-5xl (48px) at xl.
      */
      @utility nav-link {
        @apply relative inline-block text-center font-semibold text-brand-blue no-underline whitespace-nowrap;
        @apply text-xs sm:text-sm md:text-base lg:text-lg xl:text-2xl leading-relaxed;
        @apply transition-[color,transform] duration-150 ease-out;
        @apply hover:text-brand-blue-dark hover:-translate-y-px;
        @apply focus-visible:text-brand-blue-dark focus-visible:-translate-y-px focus-visible:outline-hidden;
        @apply after:content-[''] after:absolute after:inset-x-[12%] after:-bottom-1 after:h-0.5 after:rounded-full after:bg-current after:origin-center after:scale-x-0 after:transition-transform after:duration-200 after:ease-out;
        @apply hover:after:scale-x-100 focus-visible:after:scale-x-100;
      }

      @utility nav-icon {
        @apply inline-block bg-no-repeat bg-contain bg-center;
        @apply transition-[transform,opacity,filter] duration-150 ease-out;
        @apply hover:scale-105 hover:brightness-90;
        @apply focus-visible:scale-105 focus-visible:brightness-90 focus-visible:outline-hidden;
      }
    </style>
  </head>

  <body class="m-0 p-0 bg-white font-sans antialiased">
    <!-- =========================================
         NAVBAR — used as a custom element <nav-bar>.
         Custom elements must contain a hyphen (HTML spec), so we use <nav-bar>.
         Renders into Light DOM (no Shadow DOM) so Tailwind v4's browser
         build scans its utility classes and the @theme / @utility rules
         from <head> apply. Attribute hooks let pages override link
         targets without editing JS.
         ========================================= -->
    <nav-bar
      home-href="#top"
      who-href="#who-we-are"
      order-href="#order"
      favorites-href="#favorites"
      cart-href="#cart"
    ></nav-bar>

    <main id="top">
      <!--
        Hero section — Figma node 3311:1437 "Mask Group 1".
        Composes the cupcake background photo, centered headline, and CTA.
        Follows the same web-component pattern as <nav-bar>.
      -->
      <hero-section
        order-href="#order"
        headline="FRESH. SIMPLE. WHOLE."
        cta-label="ORDER NOW"
      ></hero-section>

      <!--
        Small banner — Figma node 3311:1431 ("Rectangle 1") + nine glyph
        groups (3311:1573-1605). Brand-blue band carrying the cupcake-
        flavor icons; sits directly under the hero photo. Its own
        independent <small-banner> component so other pages can reuse it
        without pulling in the hero.
      -->
      <small-banner></small-banner>
    </main>

    <!--
      Custom element definition.
      Best-practice notes:
      - Class extends HTMLElement, registered with customElements.define().
      - Light DOM (this.innerHTML) is used intentionally so Tailwind's browser
        build sees the utility classes and applies them. Shadow DOM would
        require either re-importing the global stylesheet or duplicating
        utility CSS inside the shadow root.
        Ref: https://web.dev/articles/custom-elements-v1 — "Light DOM".
      - Idempotent connectedCallback: render only when empty, so moving the
        node in the DOM doesn't blow away user state.
      - Observed attributes drive declarative href configuration.
    -->
    <script>
      class Navbar extends HTMLElement {
        static get observedAttributes() {
          return [
            "home-href",
            "who-href",
            "order-href",
            "favorites-href",
            "cart-href",
          ];
        }

        connectedCallback() {
          if (!this.isConnected) return;
          // Render once. Subsequent attribute changes patch the existing DOM.
          if (this.childElementCount === 0) this.#render();
        }

        attributeChangedCallback(name, _oldValue, newValue) {
          if (this.childElementCount === 0) return; // not yet rendered
          const selectorByAttr = {
            "home-href": '[data-role="home"]',
            "who-href": '[data-role="who"]',
            "order-href": '[data-role="order"]',
            "favorites-href": '[data-role="favorites"]',
            "cart-href": '[data-role="cart"]',
          };
          const el = this.querySelector(selectorByAttr[name]);
          if (el) el.setAttribute("href", newValue || "#");
        }

        #attr(name, fallback) {
          return this.getAttribute(name) || fallback;
        }

        #render() {
          const homeHref = this.#attr("home-href", "#top");
          const whoHref = this.#attr("who-href", "#who-we-are");
          const orderHref = this.#attr("order-href", "#order");
          const favoritesHref = this.#attr("favorites-href", "#favorites");
          const cartHref = this.#attr("cart-href", "#cart");

          this.innerHTML = `
            <header
              class="sticky top-0 z-50 w-full bg-white border-b border-brand-border
                     h-14 sm:h-16 md:h-20 lg:h-24 xl:h-32"
              data-node-id="3311:1430"
              data-name="Navbar / Rectangle 1"
            >
              <div class="flex h-full w-full items-center justify-between px-3 sm:px-4 md:px-6 lg:px-10">
                <!-- Logo lockup: CUPS [icon] CAKES. -->
                <a
                  data-role="home"
                  href="${homeHref}"
                  class="inline-flex items-center gap-1.5 sm:gap-2 md:gap-2.5
                         font-semibold text-brand-blue no-underline whitespace-nowrap
                         text-base sm:text-lg md:text-xl lg:text-2xl xl:text-4xl
                         leading-relaxed
                         transition-opacity duration-150 hover:opacity-90 focus-visible:opacity-90 focus-visible:outline-hidden"
                  data-node-id="3311:1569"
                  data-name="CUPS_&_CAKES_LOGO_2026_UPDATE_13-17"
                  aria-label="Cups & Cakes — home"
                >
                  <span data-node-id="3311:1557">CUPS</span>
                  <span
                    class="inline-block bg-cups-icon bg-no-repeat bg-contain bg-center shrink-0
                           h-[1.2em] aspect-[75.694/55.796]"
                    data-node-id="3311:1568"
                    data-name="Group 21"
                    role="img"
                    aria-label=""
                  ></span>
                  <span data-node-id="3311:1561">CAKES</span>
                </a>

                <!-- Right cluster: text links + heart + cart. -->
                <nav
                  class="flex items-center gap-3 sm:gap-4 md:gap-6 lg:gap-10"
                  aria-label="Primary"
                >
                  <a
                    data-role="who"
                    href="${whoHref}"
                    class="nav-link hidden md:inline-block"
                    data-node-id="3311:1674"
                  >WHO WE ARE</a>

                  <a
                    data-role="order"
                    href="${orderHref}"
                    class="nav-link hidden md:inline-block"
                    data-node-id="3311:1678"
                  >ORDER NOW</a>

                  <a
                    data-role="favorites"
                    href="${favoritesHref}"
                    class="nav-icon bg-heart-group h-4 sm:h-5 md:h-5 lg:h-6 aspect-[111.961/36]"
                    data-node-id="3311:1689"
                    data-name="Group 49"
                    aria-label="Account / favorites"
                  ></a>

                  <a
                    data-role="cart"
                    href="${cartHref}"
                    class="nav-icon bg-cart-icon h-5 sm:h-6 md:h-7 lg:h-8 aspect-[41.479/46.541]"
                    data-node-id="3311:1695"
                    data-name="C&C_CART_ICON"
                    aria-label="Shopping cart"
                  ></a>
                </nav>
              </div>
            </header>
          `;
        }
      }

      // Guard against double-definition (HMR, multiple imports).
      // Custom element names must contain a hyphen per the HTML spec.
      if (!customElements.get("nav-bar")) {
        customElements.define("nav-bar", Navbar);
      }

      /*
        Hero — Figma 3311:1437 (Mask Group 1) + 3311:1446 (headline)
                + 3311:1450/1451 (CTA) + 3311:1444 (scroll indicator).
        The brand-blue flavor band that used to live here has been
        extracted to <small-banner>; the hero now ends at the photo
        section, keeping responsibilities tight.
        Same component pattern as Navbar: Light DOM, idempotent, observed
        attributes, data-role-based attribute patching.
      */
      class Hero extends HTMLElement {
        static get observedAttributes() {
          return ["headline", "cta-label", "order-href"];
        }

        connectedCallback() {
          if (this.childElementCount === 0) this.#render();
        }

        attributeChangedCallback(name, _oldValue, newValue) {
          if (this.childElementCount === 0) return;
          if (name === "order-href") {
            const el = this.querySelector('[data-role="order"]');
            if (el) el.setAttribute("href", newValue || "#");
          } else if (name === "headline") {
            const el = this.querySelector('[data-role="headline"]');
            if (el) el.textContent = newValue || "";
          } else if (name === "cta-label") {
            const el = this.querySelector('[data-role="cta-label"]');
            if (el) el.textContent = newValue || "";
          }
        }

        #attr(name, fallback) {
          return this.getAttribute(name) || fallback;
        }

        #render() {
          const headline = this.#attr("headline", "FRESH. SIMPLE. WHOLE.");
          const ctaLabel = this.#attr("cta-label", "ORDER NOW");
          const orderHref = this.#attr("order-href", "#order");

          this.innerHTML = `
            <!-- Hero photo + overlay. Aspect-ratio holds the 1920×960 shape. -->
            <section
              class="relative w-full bg-hero-cupcakes bg-cover bg-center aspect-[1920/960]
                     flex flex-col items-center justify-center"
              data-node-id="3311:1437"
              data-name="Mask Group 1"
            >
              <!-- Soft pink tint overlay (Figma 3311:1445, brand-pink @ 20%).
                   Sits above the photo, below the content. -->
              <div
                class="absolute inset-0 bg-brand-pink/20 pointer-events-none"
                data-node-id="3311:1445"
                data-name="Rectangle 4 (tint)"
                aria-hidden="true"
              ></div>

              <!-- Cupcake logo glyph above the headline (Figma 3311:1460).
                   Native ratio ~117/86. -->
              <span
                class="relative bg-hero-logo bg-no-repeat bg-contain bg-center
                       h-10 sm:h-12 md:h-14 lg:h-16 xl:h-20 aspect-[117/86]
                       mb-4 sm:mb-5 md:mb-6 drop-shadow-md"
                data-node-id="3311:1460"
                data-name="CUPS_&_CAKES_LOGO_2026_UPDATE_14"
                role="img"
                aria-label="Cups & Cakes"
              ></span>

              <!-- Headline. Figma: Inter Medium 90px white, letter-spacing normal.
                   Reference paints ~56px under scale(0.625); text-5xl/text-6xl
                   land closest at lg/xl. -->
              <h1
                data-role="headline"
                class="relative text-white font-medium text-center
                       text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl
                       leading-tight drop-shadow-md
                       m-0 px-4"
                data-node-id="3311:1446"
              ></h1>

              <!-- CTA button. Figma: 366×101 blue/border, white Inter Medium 40px. -->
              <a
                data-role="order"
                href="${orderHref}"
                class="relative mt-6 sm:mt-8 md:mt-10 lg:mt-12
                       inline-flex items-center justify-center
                       bg-brand-blue text-white font-medium no-underline
                       border border-brand-border
                       h-10 sm:h-12 md:h-14 lg:h-16 xl:h-20
                       w-48 sm:w-56 md:w-64 lg:w-72 xl:w-80
                       text-base sm:text-lg md:text-xl lg:text-2xl xl:text-3xl
                       transition-[transform,filter] duration-150 ease-out
                       hover:brightness-110 hover:-translate-y-px
                       focus-visible:brightness-110 focus-visible:-translate-y-px focus-visible:outline-hidden"
                data-node-id="3311:1450"
                data-name="Rectangle 5 + ORDER NOW"
                aria-label="Order cupcakes now"
              ><span data-role="cta-label"></span></a>

              <!-- Scroll-indicator decoration (Group 3). Native ratio 137:18.
                   Positioned at the bottom of the hero, centered. -->
              <span
                class="absolute bottom-3 sm:bottom-4 md:bottom-5 lg:bottom-6
                       left-1/2 -translate-x-1/2
                       bg-hero-scroll bg-no-repeat bg-contain bg-center
                       w-20 sm:w-24 md:w-28 lg:w-32 aspect-[137/18]
                       opacity-90"
                data-node-id="3311:1444"
                data-name="Group 3"
                role="img"
                aria-label="Scroll for more"
              ></span>
            </section>
          `;

          // Inject user-controlled text after innerHTML so attribute values
          // are never interpolated as HTML (textContent escapes everything).
          const h1 = this.querySelector('[data-role="headline"]');
          if (h1) h1.textContent = headline;
          const ctaSpan = this.querySelector('[data-role="cta-label"]');
          if (ctaSpan) ctaSpan.textContent = ctaLabel;
        }
      }

      if (!customElements.get("hero-section")) {
        customElements.define("hero-section", Hero);
      }

      /*
        SmallBanner — Figma 3311:1431 ("Rectangle 1", brand-blue band)
          with nine flavor glyphs (3311:1573-1605, Groups 22-30).
        Standalone strip that can sit under any section. No configurable
        text or links yet; icons are decorative and tagged with
        `data-flavor` so future hover/order interactions can hook in.
        Same Light-DOM / idempotent-render pattern as the other components.
      */
      class SmallBanner extends HTMLElement {
        connectedCallback() {
          if (this.childElementCount === 0) this.#render();
        }

        #render() {
          // The Figma file ships nine identical cupcake glyphs (Groups
          // 22-30 / nodes 3311:1573-1605); the same SVG (bg-flavor) is
          // reused nine times to avoid importing duplicates.
          const icons = Array.from({ length: 9 }, (_, i) => `
              <span class="bg-flavor bg-no-repeat bg-contain bg-center h-10 sm:h-12 md:h-14 lg:h-16 xl:h-20 aspect-[118/110] shrink-0"
                    data-flavor="${i + 1}"
                    role="img" aria-label="Cupcake flavor ${i + 1}"></span>`)
            .join("");

          this.innerHTML = `
            <section
              class="w-full bg-brand-blue border-y border-brand-border
                     h-16 sm:h-20 md:h-24 lg:h-28 xl:h-32
                     flex items-center justify-between
                     px-3 sm:px-4 md:px-6 lg:px-10"
              data-node-id="3311:1431"
              data-name="Rectangle 1 (flavor band)"
              aria-label="Cupcake flavors"
            >${icons}
            </section>
          `;
        }
      }

      if (!customElements.get("small-banner")) {
        customElements.define("small-banner", SmallBanner);
      }
    </script>
  </body>
</html>
