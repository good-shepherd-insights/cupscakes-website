---
/**
 * Shopping Cart (Figma 3311:4172).
 *
 * Renders the page heading, a stack of cart line-item cards, the
 * subtotal block, and the curved CHECKOUT pill.
 *
 * Each line-item card mirrors the Figma row:
 * - Side-strip accent (blue for personal cakes, pink for cupcakes)
 * - Product image
 * - Stacked label/value cells: Product, Flavor, Frosting Color/Quantity, Occasion, Price
 * - "Edit" pill on the right
 *
 * The Figma frame uses a 5-column desktop grid; the component uses CSS
 * grid with the same column ratios at xl, falling back to a stacked
 * 2-column layout below md and a single column on small mobile.
 */

interface CartItem {
  id: string;
  product: string;
  flavor: string;
  variantLabel: string;
  variantValue: string;
  occasion: string;
  price: string;
  imageSrc: string;
  imageAlt: string;
  accent: "blue" | "pink";
  editHref: string;
}

interface Props {
  heading: string;
  productHeading: string;
  flavorHeading: string;
  occasionHeading: string;
  priceHeading: string;
  editLabel: string;
  subtotalLabel: string;
  subtotalValue: string;
  checkoutLabel: string;
  checkoutHref: string;
  items: CartItem[];
}

const {
  heading,
  productHeading,
  flavorHeading,
  occasionHeading,
  priceHeading,
  editLabel,
  subtotalLabel,
  subtotalValue,
  checkoutLabel,
  checkoutHref,
  items,
} = Astro.props;

// Stable per-row classes; literals so Tailwind sees every utility.
const accentBlue = "bg-brand-blue";
const accentPink = "bg-brand-pink";
const labelClass =
  "block font-medium text-black leading-[normal] " +
  "text-sm sm:text-base md:text-lg lg:text-xl xl:text-2xl";
const valueClass =
  "block font-normal text-black leading-[normal] " +
  "text-sm sm:text-base md:text-lg lg:text-xl xl:text-2xl";
---

<section
  class="relative w-full bg-white"
  data-node-id="3311:4172"
  data-name="Shopping Cart"
>
  <div
    class="mx-auto w-full max-w-screen-2xl
           px-5 sm:px-8 md:px-12 lg:px-16 xl:px-[85px]
           pt-8 sm:pt-12 md:pt-16 lg:pt-20 xl:pt-24
           pb-12 sm:pb-16 md:pb-20 lg:pb-24 xl:pb-28"
  >
    <h1
      class="m-0 font-medium text-black leading-[normal]
             text-3xl sm:text-4xl md:text-5xl lg:text-6xl xl:text-7xl
             mb-8 sm:mb-10 md:mb-12 lg:mb-14 xl:mb-16"
      data-node-id="3311:4173"
    >{heading}</h1>

    <ul class="list-none m-0 p-0 flex flex-col">
      {items.map((item, i) => (
        <li
          class={`block ${i > 0 ? "mt-8 sm:mt-10 md:mt-12 lg:mt-14 xl:mt-16" : ""}`}
          data-name={`Cart row ${i + 1}`}
        >
          {/* Edit pill (3311:4321 / 3311:4328) sits ABOVE the row, right-aligned. */}
          <div class="flex justify-end mb-4 sm:mb-5 md:mb-6">
            <a
              href={item.editHref}
              class="inline-flex items-center justify-center text-center
                     font-medium text-brand-blue no-underline
                     bg-white border border-brand-border
                     h-10 sm:h-11 md:h-12 lg:h-12 xl:h-14
                     w-32 sm:w-36 md:w-40 lg:w-44 xl:w-52
                     text-sm sm:text-base md:text-base lg:text-lg xl:text-xl
                     transition-[transform,filter] duration-150 ease-out
                     hover:brightness-95 hover:-translate-y-px
                     focus-visible:brightness-95 focus-visible:-translate-y-px focus-visible:outline-hidden"
              data-node-id={i === 0 ? "3311:4321" : "3311:4328"}
            >{editLabel}</a>
          </div>

          {/* Row body — bordered top + bottom, contains side-strip + image + label/value grid. */}
          <div
            class="relative grid items-center gap-x-4 sm:gap-x-5 md:gap-x-6 lg:gap-x-8
                   grid-cols-[auto_auto_minmax(0,1fr)]
                   border-t border-b border-black py-4 sm:py-5 md:py-6 lg:py-7 xl:py-8"
            data-node-id={i === 0 ? "3311:4185" : "3311:4186"}
          >
            {/* Color side-strip (3311:4185 / 3311:4186). */}
            <span
              class={`block self-stretch w-2 sm:w-2.5 md:w-3 lg:w-3.5 xl:w-4
                      border border-brand-border
                      ${item.accent === "blue" ? accentBlue : accentPink}`}
              aria-hidden="true"
            ></span>

            {/* Product image (3311:4227 / 3311:4332). */}
            <img
              src={item.imageSrc}
              alt={item.imageAlt}
              class="block object-contain
                     h-14 sm:h-16 md:h-20 lg:h-24 xl:h-28
                     w-auto"
              data-node-id={i === 0 ? "3311:4227" : "3311:4331"}
              loading="lazy"
              decoding="async"
            />

            {/* Header labels (top) + value cells (bottom) — 5 columns at lg+. */}
            <div
              class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-x-4 gap-y-2 md:gap-y-3"
            >
              <div>
                <span class={labelClass}>{productHeading}</span>
                <span class={valueClass}>{item.product}</span>
              </div>
              <div>
                <span class={labelClass}>{flavorHeading}</span>
                <span class={valueClass}>{item.flavor}</span>
              </div>
              <div>
                <span class={labelClass}>{item.variantLabel}</span>
                <span class={valueClass}>{item.variantValue}</span>
              </div>
              <div>
                <span class={labelClass}>{occasionHeading}</span>
                <span class={valueClass}>{item.occasion}</span>
              </div>
              <div>
                <span class={labelClass}>{priceHeading}</span>
                <span class={valueClass}>{item.price}</span>
              </div>
            </div>
          </div>
        </li>
      ))}
    </ul>

    {/* Subtotal stack (3311:4219 / 3311:4223). */}
    <div
      class="mt-8 sm:mt-10 md:mt-12 lg:mt-14 xl:mt-16
             flex flex-col items-end gap-1 sm:gap-2 text-right"
    >
      <p
        class="m-0 font-medium text-black leading-[normal]
               text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl"
        data-node-id="3311:4219"
      >{subtotalLabel}</p>
      <p
        class="m-0 font-medium text-black leading-[normal]
               text-2xl sm:text-3xl md:text-4xl lg:text-5xl xl:text-6xl"
        data-node-id="3311:4223"
      >{subtotalValue}</p>
    </div>

    {/* CHECKOUT button (3311:4333 / 3311:4334). Flat brand-blue rectangle
        with brand-border outline, matching the Figma Path 9 shape. */}
    <div class="mt-8 sm:mt-10 md:mt-12 lg:mt-14 xl:mt-16 flex justify-center">
      <a
        href={checkoutHref}
        class="inline-flex items-center justify-center text-center no-underline
               bg-brand-blue text-white font-medium
               border border-brand-border
               h-14 sm:h-16 md:h-20 lg:h-24 xl:h-28
               w-full max-w-md sm:max-w-lg md:max-w-xl lg:max-w-2xl xl:max-w-3xl
               text-xl sm:text-2xl md:text-3xl lg:text-4xl xl:text-5xl
               px-8
               transition-[transform,filter] duration-150 ease-out
               hover:brightness-95 hover:-translate-y-px
               focus-visible:brightness-95 focus-visible:-translate-y-px focus-visible:outline-hidden"
        data-node-id="3311:4334"
      >{checkoutLabel}</a>
    </div>
  </div>
</section>
