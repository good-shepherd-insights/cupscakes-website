---
interface Props {
  homeHref: string;
  whoHref: string;
  orderHref: string;
  productsHref: string;
  favoritesHref: string;
  cartHref: string;
  shopHref: string;
  /**
   * Marks one of the top-level nav links as the current page so the
   * navbar renders a brand-pink underline beneath that link (Figma
   * 3311:3222 / Rectangle 35). Defaults to `undefined` so existing
   * call sites render no indicator.
   */
  activeLink?: "who" | "order" | "products" | "shop";
  /**
   * "store" swaps the "WHO WE ARE" / "ORDER NOW" links for a single
   * "PRODUCTS" link back to the catalog. Both of those links lead away
   * from the catalog and back toward the home page's own flows — fine
   * everywhere else, but on /products and product detail pages it pulls
   * shoppers out of the store they're actively browsing. Defaults to
   * "site" so every other page's navbar is unchanged.
   */
  mode?: "site" | "store";
  /** Social links surfaced at the bottom of the mobile popout menu. */
  facebookHref?: string;
  instagramHref?: string;
}

const {
  homeHref,
  whoHref,
  orderHref,
  productsHref,
  favoritesHref,
  cartHref,
  shopHref,
  activeLink,
  mode = "site",
  facebookHref = "#",
  instagramHref = "#",
} = Astro.props;

// Active-link underline shared classes. Absolutely positioned below the
// nav link so it does not affect link layout. Tailwind sees the full
// literal string for the JIT scanner.
const activeUnderlineClass =
  "absolute left-1/2 -translate-x-1/2 -bottom-1 sm:-bottom-1.5 md:-bottom-2\n   h-0.5 sm:h-[3px] md:h-1 w-3/4 rounded-full bg-brand-pink";
---

<header
  class="sticky top-0 z-50 w-full bg-white border-b border-brand-border
         h-14 sm:h-16 md:h-20 lg:h-24 xl:h-32"
  data-node-id="3311:1430"
  data-name="Navbar / Rectangle 1"
>
  <div class="flex h-full w-full items-center justify-between px-3 sm:px-4 md:px-6 lg:px-10">
    <button
      type="button"
      id="mobile-menu-toggle"
      class="mobile-menu-toggle md:hidden inline-flex flex-col items-center justify-center gap-1.5
             shrink-0 mr-2 p-1.5 -ml-1.5 bg-transparent border-0 cursor-pointer
             focus-visible:outline-hidden"
      aria-label="Open menu"
      aria-controls="mobile-menu"
      aria-expanded="false"
    >
      <span class="block h-0.5 w-6 rounded-full bg-brand-blue transition-transform duration-200"></span>
      <span class="block h-0.5 w-6 rounded-full bg-brand-blue transition-opacity duration-200"></span>
      <span class="block h-0.5 w-6 rounded-full bg-brand-blue transition-transform duration-200"></span>
    </button>

    <a
      href={homeHref}
      class="inline-flex items-center gap-1.5 sm:gap-2 md:gap-2.5
             font-semibold text-brand-blue no-underline whitespace-nowrap
             text-base sm:text-lg md:text-xl lg:text-2xl xl:text-4xl
             leading-relaxed
             transition-opacity duration-150 hover:opacity-90 focus-visible:opacity-90 focus-visible:outline-hidden"
      data-node-id="3311:1569"
      data-name="CUPS_&_CAKES_LOGO_2026_UPDATE_13-17"
      aria-label="Cups & Cakes — home"
    >
      <span data-node-id="3311:1557">CUPS</span>
      <span
        class="inline-block bg-cups-icon bg-no-repeat bg-contain bg-center shrink-0
               h-[1.2em] aspect-[75.694/55.796]"
        data-node-id="3311:1568"
        data-name="Group 21"
        role="img"
        aria-label=""
      ></span>
      <span data-node-id="3311:1561">CAKES</span>
    </a>

    <nav
      class="flex items-center gap-3 sm:gap-4 md:gap-6 lg:gap-10"
      aria-label="Primary"
    >
      {mode === "store" ? (
        <a
          href={productsHref}
          class="nav-link relative hidden md:inline-block"
          data-name="Products"
          aria-current={activeLink === "products" ? "page" : undefined}
        >
          <span>PRODUCTS</span>
          {activeLink === "products" && (
            <span
              aria-hidden="true"
              class={activeUnderlineClass}
              data-node-id="3311:3222"
              data-name="Active link underline"
            ></span>
          )}
        </a>
      ) : (
        <>
          <a
            href={whoHref}
            class="nav-link relative hidden md:inline-block"
            data-node-id="3311:1674"
            aria-current={activeLink === "who" ? "page" : undefined}
          >
            <span>WHO WE ARE</span>
            {activeLink === "who" && (
              <span
                aria-hidden="true"
                class={activeUnderlineClass}
                data-node-id="3311:3222"
                data-name="Active link underline"
              ></span>
            )}
          </a>

          <a
            href={orderHref}
            class="nav-link relative hidden md:inline-block"
            data-node-id="3311:1678"
            aria-current={activeLink === "order" ? "page" : undefined}
          >
            <span>ORDER NOW</span>
            {activeLink === "order" && (
              <span
                aria-hidden="true"
                class={activeUnderlineClass}
                data-node-id="3311:3222"
                data-name="Active link underline"
              ></span>
            )}
          </a>

          <a
            href={shopHref}
            class="nav-link relative hidden md:inline-block"
            aria-current={activeLink === "shop" ? "page" : undefined}
          >
            <span>OUR SHOP</span>
            {activeLink === "shop" && (
              <span aria-hidden="true" class={activeUnderlineClass}></span>
            )}
          </a>
        </>
      )}

      <a
        href={favoritesHref}
        class="nav-icon bg-heart-group h-4 sm:h-5 md:h-5 lg:h-6 aspect-[111.961/36]"
        data-node-id="3311:1689"
        data-name="Group 49"
        aria-label="Account / favorites"
      ></a>

      <div class="cart-container relative inline-flex shrink-0">
        <a
          href={cartHref}
          data-astro-reload
          class="cart-link nav-icon bg-cart-icon h-5 sm:h-6 md:h-7 lg:h-8 aspect-[41.479/46.541]"
          data-node-id="3311:1695"
          data-name="C&C_CART_ICON"
          aria-label="Shopping cart"
        ></a>
        <span
          class="snipcart-items-count pointer-events-none absolute -top-1.5 -right-1.5 flex min-w-4 h-4 items-center justify-center rounded-full px-0.5 bg-brand-pink text-white text-[10px] font-bold leading-none"
          aria-hidden="true"
          hidden
        ></span>
      </div>
    </nav>
  </div>

  {/* Mobile popout menu (md:hidden). Slides in from the left; mirrors the
      Figma popout: blue header cap with the & glyph, pink panel with the
      primary links stacked, social icons pinned to the bottom. */}
  <div
    id="mobile-menu"
    class="mobile-menu md:hidden"
    aria-hidden="true"
  >
    <div
      id="mobile-menu-overlay"
      class="mobile-menu-overlay"
    ></div>

    <div class="mobile-menu-panel">
      {/* Blue header cap */}
      <div class="relative flex h-28 shrink-0 items-center justify-center bg-brand-blue">
        <button
          type="button"
          id="mobile-menu-close"
          class="absolute right-4 top-4 inline-flex h-8 w-8 items-center justify-center
                 rounded-full bg-white/0 text-2xl leading-none text-white
                 transition-colors duration-150 hover:bg-white/20 focus-visible:outline-hidden"
          aria-label="Close menu"
        >&times;</button>
        <a
          href={homeHref}
          class="block h-20 w-24"
          aria-label="Cups & Cakes — home"
        >
          <img
            src="/assets/order-logo-small.svg"
            alt=""
            aria-hidden="true"
            class="h-full w-full object-contain"
          />
        </a>
      </div>

      {/* Pink body with stacked links + socials */}
      <div class="flex flex-1 flex-col items-center bg-brand-pink px-6 py-12 text-center">
        <nav class="flex flex-1 flex-col items-center justify-center gap-12" aria-label="Mobile">
          {mode === "store" ? (
            <a href={productsHref} class="mobile-menu-link">PRODUCTS</a>
          ) : (
            <>
              <a href={whoHref} class="mobile-menu-link">WHO WE ARE</a>
              <a href={orderHref} class="mobile-menu-link">ORDER NOW</a>
              <a href={shopHref} class="mobile-menu-link">OUR SHOP</a>
            </>
          )}
        </nav>

        <div class="flex items-center justify-center gap-6 pb-6">
          <a
            href={facebookHref}
            class="mobile-menu-social bg-facebook"
            aria-label="Facebook"
          ></a>
          <a
            href={instagramHref}
            class="mobile-menu-social bg-instagram"
            aria-label="Instagram"
          ></a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import { initCartBadgeStore, applyCartBadge, initCartShakeAnimation } from "../../lib/snipcart/cartBadge";

  // Mobile popout menu open/close wiring. Re-runs on Astro view
  // transitions via astro:page-load so the handlers always bind.
  function initMobileMenu() {
    const toggle = document.getElementById("mobile-menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const overlay = document.getElementById("mobile-menu-overlay");
    const closeBtn = document.getElementById("mobile-menu-close");
    if (!toggle || !menu || !overlay) return;

    // Guard: only register once per element pair. Astro's page-load fires
    // after every client-side navigation; without this guard, handlers
    // stack up and each click toggles open then immediately closed again.
    if (toggle.dataset.menuBound) return;
    toggle.dataset.menuBound = "1";

    const open = () => {
      menu.classList.add("is-open");
      menu.setAttribute("aria-hidden", "false");
      toggle.setAttribute("aria-expanded", "true");
      toggle.setAttribute("aria-label", "Close menu");
      document.body.style.overflow = "hidden";
    };

    const close = () => {
      menu.classList.remove("is-open");
      menu.setAttribute("aria-hidden", "true");
      toggle.setAttribute("aria-expanded", "false");
      toggle.setAttribute("aria-label", "Open menu");
      document.body.style.overflow = "";
    };

    toggle.addEventListener("click", () =>
      menu.classList.contains("is-open") ? close() : open()
    );
    overlay.addEventListener("click", close);
    closeBtn?.addEventListener("click", close);
    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu.classList.contains("is-open")) close();
    });
  }

  initMobileMenu();
  document.addEventListener("astro:page-load", initMobileMenu);
  document.addEventListener("snipcart.ready", initCartBadgeStore);
  document.addEventListener("snipcart.ready", initCartShakeAnimation);
  document.addEventListener("astro:page-load", applyCartBadge);
</script>

