---
const allFlavors = [1, 2, 3, 4, 5, 6, 7, 8, 9];
const mobileFlavors = [1, 3, 5, 7, 9];
---

<section
  class="w-full bg-brand-blue border-y border-brand-border
         h-16 sm:h-20 md:h-24 lg:h-28 xl:h-32
         flex items-center"
  data-node-id="3311:1431"
  data-name="Rectangle 1 (flavor band)"
  aria-label="Cupcake flavors"
>
  {/* Mobile: 5 icons with generous spacing */}
  <div class="flex lg:hidden w-full justify-around px-8 sm:px-14">
    {mobileFlavors.map((n) => (
      <span
        class="bg-flavor bg-no-repeat bg-contain bg-center h-10 sm:h-12 aspect-[118/110] shrink-0"
        data-flavor={n}
        role="img"
        aria-label={`Cupcake flavor ${n}`}
      ></span>
    ))}
  </div>

  {/* Desktop: all 9 icons */}
  <div class="hidden lg:flex w-full justify-between px-10">
    {allFlavors.map((n) => (
      <span
        class="bg-flavor bg-no-repeat bg-contain bg-center h-14 lg:h-16 xl:h-20 aspect-[118/110] shrink-0"
        data-flavor={n}
        role="img"
        aria-label={`Cupcake flavor ${n}`}
      ></span>
    ))}
  </div>
</section>
