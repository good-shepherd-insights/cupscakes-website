---
/**
 * Products page CUPCAKES grid. Figma 3311:2985 rows at y=1227..4082.
 *
 * Renders a 3-column responsive grid (1 / 2 / 3) of CupcakeFlavorCard.
 * The H2 is the in-page anchor target (#cupcakes) used by the
 * CategoryHeader link.
 */
import CupcakeFlavorCard from "./CupcakeFlavorCard.astro";

type FlavorKey =
  | "chocolate"
  | "vanilla"
  | "carrot"
  | "butter-pecan"
  | "pumpkin"
  | "lemon"
  | "strawberry";

interface Flavor {
  key: FlavorKey;
  name: string;
  description: string;
  price: string;
  imageSrc: string;
  imageAlt: string;
  orderHref: string;
}

interface Props {
  heading: string;
  caption: string;
  flavors: ReadonlyArray<Flavor>;
}

const { heading, caption, flavors } = Astro.props;
---

<section
  id="cupcakes"
  aria-labelledby="products-cupcakes-heading"
  class="w-full bg-white
         scroll-mt-24
         px-4 sm:px-6 md:px-10 lg:px-14
         py-10 sm:py-14 md:py-20 lg:py-24"
  data-node-id="3311:2985"
  data-name="CUPCAKES grid"
>
  <div class="mx-auto max-w-screen-2xl flex flex-col items-center
              gap-[1.35rem] sm:gap-[1.8rem] md:gap-[2.25rem] lg:gap-[2.7rem]">
    <div class="flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left
                gap-2 sm:gap-[7.2rem] md:gap-[9.0rem] lg:gap-[10.8rem] w-full">
      <h2
        id="products-cupcakes-heading"
        class="m-0 text-black font-medium leading-[1.125]
               text-3xl sm:text-[3.34rem] md:text-[3.89rem] lg:text-[4.45rem] xl:text-[66.7px]"
      >
        {heading}
      </h2>

      <p
        class="m-0 text-brand-pink font-medium leading-tight sm:leading-[46px]
               text-lg sm:text-[1.33rem] md:text-[1.56rem] lg:text-[1.78rem] xl:text-[2.00rem]"
      >
        {caption}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3
                gap-[1.35rem] sm:gap-[1.8rem] md:gap-[2.25rem] w-full">
      {flavors.map((f) => (
        <CupcakeFlavorCard
          flavorKey={f.key}
          name={f.name}
          description={f.description}
          price={f.price}
          imageSrc={f.imageSrc}
          imageAlt={f.imageAlt}
          orderHref={f.orderHref}
        />
      ))}
    </div>
  </div>
</section>
