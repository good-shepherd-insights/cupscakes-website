---
/**
 * Products page PERSONAL CAKES grid. Figma 3311:2985 row at y=4219..5408.
 *
 * Two cards side-by-side at sm+, stacked on mobile. H2 is the in-page
 * anchor target (#personal-cakes) used by the CategoryHeader link.
 */
import PersonalCakeCard from "./PersonalCakeCard.astro";

interface Item {
  key: "chocolate" | "vanilla";
  name: string;
  description: string;
  price: string;
  imageSrc: string;
  imageAlt: string;
  orderHref: string;
}

interface Props {
  heading: string;
  caption: string;
  items: ReadonlyArray<Item>;
}

const { heading, caption, items } = Astro.props;
---

<section
  id="personal-cakes"
  aria-labelledby="products-personal-cakes-heading"
  class="w-full bg-white
         scroll-mt-24
         px-4 sm:px-6 md:px-10 lg:px-14
         py-10 sm:py-14 md:py-20 lg:py-24"
  data-node-id="3311:2985"
  data-name="PERSONAL CAKES grid"
>
  <div class="mx-auto max-w-screen-2xl flex flex-col items-center
              gap-[1.35rem] sm:gap-[1.8rem] md:gap-[2.25rem] lg:gap-[2.7rem]">
    <div class="flex flex-col sm:flex-row items-center sm:items-start text-center sm:text-left
                gap-2 sm:gap-[7.2rem] md:gap-[9.0rem] lg:gap-[10.8rem] w-full">
      <h2
        id="products-personal-cakes-heading"
        class="m-0 text-black font-normal leading-[1.125]
               text-3xl sm:text-[3.34rem] md:text-[3.89rem] lg:text-[4.45rem] xl:text-[66.7px]"
      >
        <span class="block">{heading.split(' ')[0]}</span>
        <span class="block">{heading.split(' ').slice(1).join(' ')}</span>
      </h2>

      <p
        class="m-0 text-brand-pink font-medium leading-tight sm:leading-[46px]
               text-lg sm:text-[1.33rem] md:text-[1.56rem] lg:text-[1.78rem] xl:text-[2.00rem]"
      >
        {caption}
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-3
                gap-[1.35rem] sm:gap-[1.8rem] md:gap-[2.25rem] w-full">
      {items.map((c) => (
        <PersonalCakeCard
          name={c.name}
          description={c.description}
          price={c.price}
          imageSrc={c.imageSrc}
          imageAlt={c.imageAlt}
          orderHref={c.orderHref}
        />
      ))}
    </div>
  </div>
</section>
