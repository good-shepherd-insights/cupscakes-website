---
/**
 * Personal Cake product detail page content.
 *
 * Figma source: file QfJe3qKtxeGOelVBqyEl3L, node 3311:2219
 * ("ORDER NOW: PERSONAL CAKE", 1920px wide design).
 *
 * Layout (1920px canvas, all values from get_design_context):
 *
 *   - Page background: white.
 *   - Breadcrumb (3311:2297) at left=58 / top=205 — Inter Thin 30px
 *     for "Home / Order Now / ", Inter Regular 30px for
 *     "Personal Cakes". Both black.
 *   - Product image (3311:2319 "C&C_PERSONAL_CAKE_PINK_003") at
 *     left=107 / top=346, 694×543, object-cover. Hosted at
 *     /assets/personal-cake-product.png.
 *   - Title "Personal Cake" (3311:2220) at left=998 / top=286,
 *     Inter Medium 95px black, width 729.
 *   - Subtitle (3311:2228) at left=998 / top=429, Inter Medium 35px
 *     black, width 807: "Small in size but big in bringing joy to
 *     each bite!"
 *   - Italic line (3311:2232) at left=998 / top=496, Inter Light
 *     Italic 35px black, width 807: "Serves 3-4 people."
 *   - "Flavor:" label (3311:2301) at left=998 / top=558,
 *     Inter Light 35px black.
 *   - Flavor buttons (3311:2306/2313):
 *       Chocolate at (998, 653), Vanilla at (1282, 653).
 *       Each 238×65 white fill, #707070 1px border, NO radius.
 *       Label Inter Medium 25px black, centered.
 *   - "Frosting Color: …" label (3311:2320) at left=998 / top=769,
 *     Inter Light 35px black for "Frosting Color: ", Inter Regular
 *     35px black for "(please choose up to 2 colors)", width 762.
 *   - Frosting buttons (238×65 each, white/#707070, label
 *     Inter Medium 25px black):
 *       Red    (998,  864)
 *       Blue   (1282, 864)
 *       Green  (1566, 864)
 *       Yellow (998,  985)
 *       Purple (1282, 985)
 *       Pink   (1566, 985)
 *       White  (998,  1106)
 *       Custom (1282, 1106)
 *   - "Occassion:" label (3311:2236) at left=998 / top=1222,
 *     Inter Light 35px black (Figma spelling intentional).
 *   - Occasion buttons (same 238×65 style):
 *       Regular (998,  1315)
 *       Birthday(1282, 1315)
 *       Wedding (1566, 1315)
 *       Holiday (998,  1429)
 *       Other   (1282, 1429)
 *   - ADD TO CART pill (3311:2281): brand-pink container 402×110
 *     at (998, 1569), label Inter Medium 40px WHITE centered.
 *     Background asset is /assets/add-to-cart-pill.svg (the Path 9
 *     rounded pink rectangle from Figma).
 *   - Price "$0.00" (3311:2224) at left=998 / top=1730,
 *     Inter Medium 85px black, width 729.
 *
 * The Figma uses absolute positioning on a 1920-wide canvas. We
 * preserve the exact visual using a two-column grid at lg+ that
 * matches the image-left / form-right composition, and stacks
 * (image then form) below lg. All type sizes and colors are kept
 * verbatim at xl (the Figma "design" size) and scale down fluidly.
 *
 * Color literals:
 *   - #707070  — button stroke (from Figma).
 *   - black     — body and label color (from Figma).
 *   - brand-pink (#eb9cf9) — ADD TO CART pill fill (matches Path 9
 *     SVG; reuses existing brand-pink token).
 */

import Button from "../ui/Button.astro";
import Breadcrumb from "../ui/Breadcrumb.astro";
import type { CustomOption } from "../../types/product";
import { routes } from "../../lib/routes";

interface Props {
  breadcrumbHrefHome: string;
  breadcrumbHrefOrder: string;
  breadcrumbLabel: string;
  title: string;
  subtitle: string;
  /** Italic line below subtitle. Omit to hide (e.g. cupcakes). */
  servingInfo?: string;
  /** Public path to the product image (defaults to the Figma asset). */
  imageSrc?: string;
  imageAlt?: string;
  /** Form submission endpoint (defaults to "#"). */
  addToCartHref?: string;
  /** Selection groups rendered in order, e.g. Flavor, Frosting Color, Quantity, Occasion. */
  customOptions: CustomOption[];
  /** Required only when a group has definesVariantRoute — used to build that group's variant links. */
  productSlug?: string;
  /** The currently selected variant slug, if any, for active-state styling. */
  currentVariantSlug?: string;
  price: string;
}

const {
  breadcrumbHrefHome,
  breadcrumbHrefOrder,
  breadcrumbLabel,
  title,
  subtitle,
  servingInfo,
  imageSrc = "/assets/personal-cake-product.png",
  imageAlt = "Personal cake with pink frosting",
  addToCartHref = "#",
  customOptions,
  productSlug,
  currentVariantSlug,
  price,
} = Astro.props;

/* Reusable button class — exactly matches Figma 238×65 white box with
   #707070 border and Inter Medium 25px black centered label. Scales
   down responsively below xl. */
const selectionBtn = [
  "inline-flex items-center justify-center",
  "bg-white border border-[#707070] no-underline text-black",
  "font-medium text-center whitespace-nowrap",
  // 238×65 at xl, fluid below
  "h-[40px] sm:h-[48px] md:h-[56px] lg:h-[60px] xl:h-[65px]",
  "w-full",
  // 25px label at xl, reduced 10% then a further 15%
  "text-[11px] sm:text-[12px] md:text-[14px] lg:text-[17px] xl:text-[20px]",
  "transition-[transform,filter] duration-150 ease-out",
  "hover:brightness-95 hover:-translate-y-px",
  "focus-visible:brightness-95 focus-visible:-translate-y-px focus-visible:outline-hidden",
  "cursor-pointer",
].join(" ");
---

<main
  class="bg-white w-full"
  data-node-id="3311:2219"
  data-name="ORDER NOW: PERSONAL CAKE"
>
  {/* Outer page container — caps width at the Figma 1920 design size and
      keeps generous horizontal padding matching the Figma 58/107 insets
      (≈3% of 1920). */}
  <div
    class="mx-auto w-full max-w-[1920px]
           px-[3vw] sm:px-[3vw] md:px-[3vw] lg:px-[3vw] xl:px-[58px]
           pt-8 sm:pt-10 md:pt-12 lg:pt-14 xl:pt-[49px]
           pb-12 sm:pb-16 md:pb-20 lg:pb-24 xl:pb-[120px]"
  >
    {/* Breadcrumb (3311:2297) — reusable component. */}
    <Breadcrumb
      items={[
        { label: "Home", href: breadcrumbHrefHome },
        { label: "Order Now", href: breadcrumbHrefOrder },
        { label: breadcrumbLabel },
      ]}
      class="mb-6 sm:mb-8 md:mb-10 lg:mb-12 xl:mb-[81px]
             text-[11px]! sm:text-[13px]! md:text-[15px]! lg:text-[19px]! xl:text-[26px]!"
    />

    {/* Two-column composition. Below lg: image stacks above the form.
        At lg+ : image on the left and form on the right with a wider
        gap between them. Image track is intentionally smaller than the
        original Figma 694px to reduce the image's visual weight. */}
    <div
      class="flex flex-col lg:flex-row justify-center
             gap-y-10 sm:gap-y-12 md:gap-y-14
             gap-x-10 sm:gap-x-12 md:gap-x-16 lg:gap-x-20 xl:gap-x-[100px]
             items-start"
    >
      {/* PRODUCT IMAGE — reduced from Figma's 694×543 (aspect preserved). */}
      <div
        class="w-full aspect-[694/543] overflow-hidden mx-auto
               max-w-[420px] lg:max-w-none lg:flex-1
               mt-0 lg:mt-[60px] xl:mt-[97px]"
        data-node-id="3311:2319"
        data-name="C&C_PERSONAL_CAKE_PINK_003"
      >
        <img
          src={imageSrc}
          alt={imageAlt}
          class="block w-full h-full object-cover pointer-events-none"
          loading="eager"
          fetchpriority="high"
          decoding="sync"
        />
      </div>

      {/* FORM COLUMN — everything Figma anchors at x=998. */}
      <form
        action={addToCartHref}
        method="post"
        class="flex flex-col w-full lg:max-w-none lg:flex-1"
      >
        {/* Title (3311:2220) — Inter Medium 95px black. Sits at Figma
            y=286 → ~37px above the image top (346). */}
        <h1
          class="m-0 text-black font-medium leading-[1.05]
                 text-[31px] sm:text-[41px] md:text-[51px] lg:text-[61px] xl:text-[81px]"
          data-node-id="3311:2220"
        >{title}</h1>

        {/* Subtitle (3311:2228) — Inter Medium 35px black. Figma y=429
            → ~143px below title baseline. */}
        <p
          class="m-0 mt-4 sm:mt-5 md:mt-6 lg:mt-8 xl:mt-[44px]
                 text-black font-medium leading-[1.15]
                 text-[13px] sm:text-[15px] md:text-[19px] lg:text-[24px] xl:text-[30px]"
          data-node-id="3311:2228"
        >{subtitle}</p>

        {/* Italic line (3311:2232) — Inter Light Italic 35px black.
            Figma y=496 → ~67px below subtitle. Omitted when absent. */}
        {servingInfo && (
          <p
            class="m-0 mt-2 sm:mt-2 md:mt-2 lg:mt-2 xl:mt-[8px]
                   text-black font-light italic leading-[1.15]
                   text-[13px] sm:text-[15px] md:text-[19px] lg:text-[24px] xl:text-[30px]"
            data-node-id="3311:2232"
          >{servingInfo}</p>
        )}

        {/* Selection groups — one generic, data-driven fieldset per
            customOptions entry (e.g. Flavor, Frosting Color, Quantity,
            Occasion). Replaces what used to be four hardcoded sections
            tied to specific Figma nodes; see FEATURE(product-catalog-extensibility).md
            for the before/after and rationale. */}
        {customOptions.map((group, i) => {
          const needsSpacer = group.options.length % 3 === 2;
          return (
            <fieldset
              class={`m-0 p-0 border-0 ${
                i === 0
                  ? "mt-6 sm:mt-7 md:mt-8 lg:mt-10 xl:mt-[55px]"
                  : "mt-8 sm:mt-10 md:mt-12 lg:mt-14 xl:mt-[78px]"
              }`}
            >
              <legend
                class="p-0 m-0 text-black leading-[1.15]
                       text-[13px] sm:text-[15px] md:text-[19px] lg:text-[24px] xl:text-[30px]"
              >
                <span class="font-light">{group.name}: </span>
                {group.helperText && <span class="font-normal">{group.helperText}</span>}
              </legend>

              <div
                class="grid grid-cols-2 sm:grid-cols-3
                       gap-x-3 sm:gap-x-4 md:gap-x-5 lg:gap-x-6 xl:gap-x-[46px]
                       gap-y-3 sm:gap-y-4 md:gap-y-5 lg:gap-y-6 xl:gap-y-[49px]
                       mt-4 sm:mt-5 md:mt-6 lg:mt-8 xl:mt-[60px]
                       max-w-[810px]"
              >
                {group.options.map((option) =>
                  group.definesVariantRoute && option.slug && productSlug ? (
                    <a
                      href={routes.productVariant(productSlug, option.slug.current)}
                      class={`${selectionBtn} ${option.slug.current === currentVariantSlug ? "bg-brand-pink! text-white!" : ""}`}
                    >
                      {option.label}
                      {!!option.priceModifier && ` (+$${option.priceModifier.toFixed(2)})`}
                    </a>
                  ) : (
                    <label class={`${selectionBtn} has-checked:bg-brand-pink! has-checked:text-white!`}>
                      <input type={group.inputType} name={group.name} value={option.label} class="sr-only" />
                      <span>
                        {option.label}
                        {!!option.priceModifier && ` (+$${option.priceModifier.toFixed(2)})`}
                      </span>
                    </label>
                  )
                )}
                {needsSpacer && <span class="hidden sm:block" aria-hidden="true"></span>}
              </div>
            </fieldset>
          );
        })}

        {/* ADD TO CART (3311:2281) — reuses the shared ui/Button. The
            `lg` solid size matches the homepage ORDER NOW CTA geometry;
            class overrides swap the fill to brand-pink to match Figma. */}
        <Button
          href={addToCartHref}
          label="ADD TO CART"
          variant="solid"
          size="lg"
          shape="square"
          class="mt-8 sm:mt-10 md:mt-12 lg:mt-16 xl:mt-[75px] bg-brand-pink! hover:bg-brand-pink!
                 text-[15px]! sm:text-[17px]! md:text-[20px]! lg:text-[26px]!"
          ariaLabel="Add to cart"
        />

        {/* Price (3311:2224) — Inter Medium 85px black, Figma y=1730
            → 51px below ADD TO CART (1569+110=1679; 1730-1679=51). */}
        <p
          class="m-0 mt-6 sm:mt-7 md:mt-9 lg:mt-10 xl:mt-[51px]
                 text-black font-medium leading-[1]
                 text-[27px] sm:text-[37px] md:text-[48px] lg:text-[58px] xl:text-[72px]"
          data-node-id="3311:2224"
        >{price}</p>
      </form>
    </div>
  </div>
</main>
