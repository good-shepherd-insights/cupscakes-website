---
/**
 * Personal Cake product detail page content.
 *
 * Figma source: file QfJe3qKtxeGOelVBqyEl3L, node 3311:2219
 * ("ORDER NOW: PERSONAL CAKE", 1920px wide design).
 *
 * Layout (1920px canvas, all values from get_design_context):
 *
 *   - Page background: white.
 *   - Breadcrumb (3311:2297) at left=58 / top=205 — Inter Thin 30px
 *     for "Home / Order Now / ", Inter Regular 30px for
 *     "Personal Cakes". Both black.
 *   - Product image (3311:2319 "C&C_PERSONAL_CAKE_PINK_003") at
 *     left=107 / top=346, 694×543, object-cover. Hosted at
 *     /assets/personal-cake-product.png.
 *   - Title "Personal Cake" (3311:2220) at left=998 / top=286,
 *     Inter Medium 95px black, width 729.
 *   - Subtitle (3311:2228) at left=998 / top=429, Inter Medium 35px
 *     black, width 807: "Small in size but big in bringing joy to
 *     each bite!"
 *   - Italic line (3311:2232) at left=998 / top=496, Inter Light
 *     Italic 35px black, width 807: "Serves 3-4 people."
 *   - "Flavor:" label (3311:2301) at left=998 / top=558,
 *     Inter Light 35px black.
 *   - Flavor buttons (3311:2306/2313):
 *       Chocolate at (998, 653), Vanilla at (1282, 653).
 *       Each 238×65 white fill, #707070 1px border, NO radius.
 *       Label Inter Medium 25px black, centered.
 *   - "Frosting Color: …" label (3311:2320) at left=998 / top=769,
 *     Inter Light 35px black for "Frosting Color: ", Inter Regular
 *     35px black for "(please choose up to 2 colors)", width 762.
 *   - Frosting buttons (238×65 each, white/#707070, label
 *     Inter Medium 25px black):
 *       Red    (998,  864)
 *       Blue   (1282, 864)
 *       Green  (1566, 864)
 *       Yellow (998,  985)
 *       Purple (1282, 985)
 *       Pink   (1566, 985)
 *       White  (998,  1106)
 *       Custom (1282, 1106)
 *   - "Occassion:" label (3311:2236) at left=998 / top=1222,
 *     Inter Light 35px black (Figma spelling intentional).
 *   - Occasion buttons (same 238×65 style):
 *       Regular (998,  1315)
 *       Birthday(1282, 1315)
 *       Wedding (1566, 1315)
 *       Holiday (998,  1429)
 *       Other   (1282, 1429)
 *   - ADD TO CART pill (3311:2281): brand-pink container 402×110
 *     at (998, 1569), label Inter Medium 40px WHITE centered.
 *     Background asset is /assets/add-to-cart-pill.svg (the Path 9
 *     rounded pink rectangle from Figma).
 *   - Price "$0.00" (3311:2224) at left=998 / top=1730,
 *     Inter Medium 85px black, width 729.
 *
 * The Figma uses absolute positioning on a 1920-wide canvas. We
 * preserve the exact visual using a two-column grid at lg+ that
 * matches the image-left / form-right composition, and stacks
 * (image then form) below lg. All type sizes and colors are kept
 * verbatim at xl (the Figma "design" size) and scale down fluidly.
 *
 * Color literals:
 *   - #707070  — button stroke (from Figma).
 *   - black     — body and label color (from Figma).
 *   - brand-pink (#eb9cf9) — ADD TO CART pill fill (matches Path 9
 *     SVG; reuses existing brand-pink token).
 */

import { stegaClean } from "@sanity/client/stega";
import Breadcrumb from "../ui/Breadcrumb.astro";
import AddToCartButton from "../snipcart/AddToCartButton.astro";
import { buildProductCartAttributes } from "../../lib/snipcart/cartItem";
import type { CustomOption } from "../../types/product";
import { routes } from "../../lib/routes";

interface Props {
  breadcrumbHrefHome: string;
  breadcrumbHrefProducts: string;
  breadcrumbLabel: string;
  title: string;
  subtitle: string;
  /** Italic line below subtitle. Omit to hide (e.g. cupcakes). */
  servingInfo?: string;
  /** Public path to the product image (defaults to the Figma asset). */
  imageSrc?: string;
  imageAlt?: string;
  /** Form submission endpoint (defaults to "#"). */
  addToCartHref?: string;
  /** Selection groups rendered in order, e.g. Flavor, Frosting Color, Quantity, Occasion. */
  customOptions: CustomOption[];
  /** Required only when a group has definesVariantRoute — used to build that group's variant links. */
  productSlug?: string;
  /** The currently selected variant slug, if any, for active-state styling. */
  currentVariantSlug?: string;
  price: string;
}

const {
  breadcrumbHrefHome,
  breadcrumbHrefProducts,
  breadcrumbLabel,
  title,
  subtitle,
  servingInfo,
  imageSrc = "/assets/personal-cake-product.png",
  imageAlt = "Personal cake with pink frosting",
  addToCartHref = "#",
  customOptions,
  productSlug,
  currentVariantSlug,
  price,
} = Astro.props;

// The one piece of Astro-specific context buildProductCartAttributes()
// can't resolve itself: URL building needs Astro.site, which only exists
// here in frontmatter. Mirrors [...variant].astro's own canonicalPath
// computation — prefer the canonical per-variant route (correct even on
// the bare, no-flavor-segment URL, where currentVariantSlug is still the
// default flavor) and fall back to the current request URL when this
// component is used without those props (e.g. preview-personal-cake.astro).
const cartItemPath =
  productSlug && currentVariantSlug
    ? routes.productVariant(productSlug, currentVariantSlug)
    : Astro.url.pathname;
const cartItemUrl = Astro.site ? new URL(cartItemPath, Astro.site).toString() : cartItemPath;

// Pre-checked defaults for radio (single-choice) groups. There's no schema
// flag for this — group/option names are just editorial strings (see
// product.ts) — so they're matched by name/label here, same strings
// cartSync.ts's bindRequiredGroupsGate() re-disables the button for if a
// selection is ever cleared.
const DEFAULT_OPTION_LABEL: Record<string, string> = {
  quantity: "1 Dozen",
  occasion: "Regular",
};

// Groups that get a free-text message textarea beneath their options,
// revealed client-side by cartSync.ts's bindMessageFields() (see
// MESSAGE_TRIGGERS there for exactly which selection reveals each one) and
// wired into cart data by cartItem.ts's matching MESSAGE_FIELD_GROUPS.
// Matched by name string, same convention as DEFAULT_OPTION_LABEL above.
// Every group here has an always-"safe" default (Regular / no Custom
// checked / 1 Dozen), so the textarea can always start server-rendered
// `hidden` with no flash of an incorrectly-visible box.
const MESSAGE_FIELD_GROUPS: Record<string, { label: string; placeholder: string }> = {
  occasion: {
    label: "Message",
    placeholder: 'e.g. "Happy 30th Birthday Sarah!"',
  },
  "frosting color": {
    label: "Custom Color Request",
    placeholder: "Tell us the custom frosting color you'd like",
  },
  quantity: {
    label: "Custom Quantity",
    placeholder: "Tell us how much you'd like (over 4 dozen)",
  },
};

// Checkbox groups that require at least one checked option before checkout
// — mirrors cartSync.ts's REQUIRED_CHECKBOX_MINIMUMS (same name-matched
// convention). Used here only for the server-rendered initial disabled
// state: checkboxes never render pre-checked, so a required checkbox group
// always starts unsatisfied.
const REQUIRED_CHECKBOX_GROUPS = new Set(["frosting color"]);

// Every radio group is required before checkout can begin, plus checkbox
// groups in REQUIRED_CHECKBOX_GROUPS. Flavor is excluded — it renders as
// `<a>` variant links, not form inputs, so it's always "selected" via the
// route itself. A radio group only starts pre-satisfied if one of its
// options matches DEFAULT_OPTION_LABEL above; otherwise the button renders
// already `disabled` so there's no flash of an enabled button before
// cartSync.ts's change listeners take over.
const hasUnselectedRequiredGroup = customOptions.some((g) => {
  if (g.definesVariantRoute) return false;
  const key = stegaClean(g.name).trim().toLowerCase();
  if (g.inputType === "checkbox") return REQUIRED_CHECKBOX_GROUPS.has(key);
  const defaultLabel = DEFAULT_OPTION_LABEL[key];
  return !g.options.some((o) => stegaClean(o.label) === defaultLabel);
});

// Server-render the price already reflecting the defaults above, so there's
// no flash of the un-modified base price before bindPriceDisplay() (in
// cartSync.ts) takes over client-side on astro:page-load.
const basePriceNumber = Number(price.replace(/[^0-9.]/g, ""));
const defaultModifierTotal = customOptions.reduce((sum, g) => {
  if (g.inputType !== "radio" || g.definesVariantRoute) return sum;
  const defaultLabel = DEFAULT_OPTION_LABEL[stegaClean(g.name).trim().toLowerCase()];
  const defaultOption = g.options.find((o) => stegaClean(o.label) === defaultLabel);
  return sum + (defaultOption?.priceModifier ?? 0);
}, 0);
const initialDisplayPrice = `$${(basePriceNumber + defaultModifierTotal).toFixed(2)}`;

const cartAttrs = buildProductCartAttributes({
  title,
  price,
  imageSrc,
  customOptions,
  productSlug,
  currentVariantSlug,
  url: cartItemUrl,
});

/* Reusable button class — exactly matches Figma 238×65 white box with
   #707070 border and Inter Medium 25px black centered label. Scales
   down responsively below xl. */
const selectionBtn = [
  "inline-flex items-center justify-center",
  "bg-white border border-[#707070] no-underline text-black",
  "font-medium text-center whitespace-nowrap",
  // 238×65 at xl, fluid below
  "h-[29px] sm:h-[34px] md:h-[40px] lg:h-[43px] xl:h-[46px]",
  "w-full",
  // 25px label at xl, reduced 10% then a further 15%, then scaled to 65%,
  // then increased 10% (floored at 10px for legibility below lg)
  "text-[11px] sm:text-[11px] md:text-[11px] lg:text-[12px] xl:text-[14px]",
  "transition-[transform,filter] duration-150 ease-out",
  "hover:brightness-95 hover:-translate-y-px",
  "focus-visible:brightness-95 focus-visible:-translate-y-px focus-visible:outline-hidden",
  "cursor-pointer",
].join(" ");
---

<main
  class="bg-white w-full"
  data-node-id="3311:2219"
  data-name="ORDER NOW: PERSONAL CAKE"
>
  {/* Outer page container — caps width at the Figma 1920 design size and
      keeps generous horizontal padding matching the Figma 58/107 insets
      (≈3% of 1920). */}
  <div
    class="mx-auto w-full max-w-[1920px]
           px-[2.15vw] sm:px-[2.15vw] md:px-[2.15vw] lg:px-[2.15vw] xl:px-[42px]
           pt-[23px] sm:pt-[29px] md:pt-[34px] lg:pt-[40px] xl:pt-[35px]
           pb-[34px] sm:pb-[46px] md:pb-[57px] lg:pb-[68px] xl:pb-[86px]"
  >
    {/* Breadcrumb (3311:2297) — reusable component. */}
    <Breadcrumb
      items={[
        { label: "Home", href: breadcrumbHrefHome },
        { label: "Products", href: breadcrumbHrefProducts },
        { label: breadcrumbLabel },
      ]}
      class="mb-[18px] sm:mb-[23px] md:mb-[29px] lg:mb-[34px] xl:mb-[58px]
             text-[11px]! sm:text-[11px]! md:text-[11px]! lg:text-[13px]! xl:text-[19px]!"
    />

    {/* Two-column composition. Below lg: image stacks above the form.
        At lg+ : image on the left and form on the right with a wider
        gap between them. Image track is intentionally smaller than the
        original Figma 694px to reduce the image's visual weight. */}
    <div
      class="flex flex-col lg:flex-row justify-center
             gap-y-[29px] sm:gap-y-[34px] md:gap-y-[40px]
             gap-x-[29px] sm:gap-x-[34px] md:gap-x-[46px] lg:gap-x-[57px] xl:gap-x-[72px]
             items-start"
    >
      {/* PRODUCT IMAGE column — keeps the 50/50 split with the form
          column at lg+ (lg:flex-1, matching the form's lg:flex-1) even
          though the image itself is capped smaller below via the inner
          wrapper's max-w, so it sits centered within its half rather
          than shrinking the column itself. */}
      <div
        class="w-full lg:flex-1
               mt-0 lg:mt-[39px] xl:mt-[63px]"
      >
        <div
          class="aspect-[694/543] overflow-hidden mx-auto
                 max-w-[394px]"
          data-node-id="3311:2319"
          data-name="C&C_PERSONAL_CAKE_PINK_003"
        >
          <img
            src={imageSrc}
            alt={imageAlt}
            class="block w-full h-full object-cover pointer-events-none"
            loading="eager"
            fetchpriority="high"
            decoding="sync"
          />
        </div>
      </div>

      {/* FORM COLUMN — everything Figma anchors at x=998. */}
      <form
        action={addToCartHref}
        method="post"
        class="flex flex-col w-full lg:max-w-none lg:flex-1"
      >
        {/* Title (3311:2220) — Inter Medium 95px black. Sits at Figma
            y=286 → ~37px above the image top (346). */}
        <h1
          class="m-0 text-black font-medium leading-[1.05]
                 text-[22px] sm:text-[30px] md:text-[36px] lg:text-[44px] xl:text-[58px]"
          data-node-id="3311:2220"
        >{title}</h1>

        {/* Subtitle (3311:2228) — Inter Medium 35px black. Figma y=429
            → ~143px below title baseline. */}
        <p
          class="m-0 mt-[11px] sm:mt-[14px] md:mt-[18px] lg:mt-[23px] xl:mt-[32px]
                 text-black font-medium leading-[1.15]
                 text-[11px] sm:text-[11px] md:text-[13px] lg:text-[18px] xl:text-[22px]"
          data-node-id="3311:2228"
        >{subtitle}</p>

        {/* Italic line (3311:2232) — Inter Light Italic 35px black.
            Figma y=496 → ~67px below subtitle. Omitted when absent. */}
        {servingInfo && (
          <p
            class="m-0 mt-[6px] sm:mt-[6px] md:mt-[6px] lg:mt-[6px] xl:mt-[6px]
                   text-black font-light italic leading-[1.15]
                   text-[11px] sm:text-[11px] md:text-[13px] lg:text-[18px] xl:text-[22px]"
            data-node-id="3311:2232"
          >{servingInfo}</p>
        )}

        {/* Selection groups — one generic, data-driven fieldset per
            customOptions entry (e.g. Flavor, Frosting Color, Quantity,
            Occasion). Replaces what used to be four hardcoded sections
            tied to specific Figma nodes; see FEATURE(product-catalog-extensibility).md
            for the before/after and rationale. */}
        {customOptions.map((group, i) => {
          const needsSpacer = group.options.length % 3 === 2;
          const messageField = MESSAGE_FIELD_GROUPS[stegaClean(group.name).trim().toLowerCase()];
          return (
            <fieldset
              class={`m-0 p-0 border-0 ${
                i === 0
                  ? "mt-[18px] sm:mt-[20px] md:mt-[23px] lg:mt-[29px] xl:mt-[40px]"
                  : "mt-[23px] sm:mt-[29px] md:mt-[34px] lg:mt-[40px] xl:mt-[56px]"
              }`}
            >
              <legend
                class="p-0 m-0 text-black leading-[1.15]
                       text-[11px] sm:text-[11px] md:text-[13px] lg:text-[18px] xl:text-[22px]"
              >
                <span class="font-light">{group.name}: </span>
                {group.helperText && <span class="font-normal">{group.helperText}</span>}
              </legend>

              <div
                class="grid grid-cols-2 sm:grid-cols-3
                       gap-x-[9px] sm:gap-x-[11px] md:gap-x-[14px] lg:gap-x-[18px] xl:gap-x-[33px]
                       gap-y-[9px] sm:gap-y-[11px] md:gap-y-[14px] lg:gap-y-[18px] xl:gap-y-[35px]
                       mt-[11px] sm:mt-[14px] md:mt-[18px] lg:mt-[23px] xl:mt-[43px]
                       max-w-[580px]"
              >
                {group.options.map((option) =>
                  group.definesVariantRoute && option.slug && productSlug ? (
                    <a
                      href={routes.productVariant(productSlug, option.slug.current)}
                      class={`${selectionBtn} ${option.slug.current === currentVariantSlug ? "bg-brand-pink! text-white!" : ""}`}
                    >
                      {option.label}
                    </a>
                  ) : (
                    <label
                      class={`${selectionBtn} has-checked:bg-brand-pink! has-checked:text-white!
                              has-disabled:opacity-40 has-disabled:cursor-not-allowed
                              has-disabled:hover:brightness-100 has-disabled:hover:translate-y-0`}
                    >
                      <input
                        type={group.inputType}
                        name={stegaClean(group.name)}
                        value={stegaClean(option.label)}
                        data-price-modifier={option.priceModifier ?? 0}
                        checked={DEFAULT_OPTION_LABEL[stegaClean(group.name).trim().toLowerCase()] === stegaClean(option.label)}
                        class="sr-only"
                      />
                      <span>{option.label}</span>
                    </label>
                  )
                )}
                {needsSpacer && <span class="hidden sm:block" aria-hidden="true"></span>}
              </div>

              {/* Message textarea — hidden by default (every group above
                  starts on a "safe" default selection, see
                  MESSAGE_FIELD_GROUPS), revealed/cleared client-side by
                  cartSync.ts's bindMessageFields() as the group's selection
                  changes. */}
              {messageField && (
                <div
                  data-message-wrapper={stegaClean(group.name)}
                  hidden
                  class="mt-[11px] sm:mt-[14px] md:mt-[18px] lg:mt-[23px] xl:mt-[32px] max-w-[580px]"
                >
                  <label
                    class="block p-0 m-0 text-black leading-[1.15]
                           text-[11px] sm:text-[11px] md:text-[13px] lg:text-[18px] xl:text-[22px]"
                  >
                    {messageField.label}
                  </label>
                  <textarea
                    data-message-for={stegaClean(group.name)}
                    placeholder={messageField.placeholder}
                    rows={3}
                    class="w-full bg-white border border-[#707070] text-black
                           mt-[6px] p-[9px]
                           text-[11px] sm:text-[11px] md:text-[11px] lg:text-[12px] xl:text-[14px]"
                  ></textarea>
                </div>
              )}
            </fieldset>
          );
        })}

        {/* ADD TO CART (3311:2281) — real Snipcart button. Visual classes
            replicate the old shared ui/Button "solid lg square" output
            exactly (border, sizing, hover/focus, brand-pink fill) now that
            this is a plain <button> instead of an <a>. */}
        <AddToCartButton
          attrs={cartAttrs}
          disabled={hasUnselectedRequiredGroup}
          class="inline-flex items-center justify-center font-medium no-underline text-center
                 border border-brand-border
                 transition-[transform,filter] duration-150 ease-out
                 hover:brightness-95 hover:-translate-y-px
                 focus-visible:brightness-95 focus-visible:-translate-y-px focus-visible:outline-hidden
                 bg-brand-pink text-white
                 disabled:opacity-40 disabled:cursor-not-allowed
                 disabled:hover:brightness-100 disabled:hover:translate-y-0
                 h-[29px] sm:h-[34px] md:h-[40px] lg:h-[48px] xl:h-[57px]
                 w-[138px] sm:w-[161px] md:w-[175px] lg:w-[195px] xl:w-[233px]
                 mt-[23px] sm:mt-[29px] md:mt-[34px] lg:mt-[46px] xl:mt-[54px]
                 text-[11px] sm:text-[12px] md:text-[14px] lg:text-[19px]"
        >ADD TO CART</AddToCartButton>

        {/* Price (3311:2224) — Inter Medium 85px black, Figma y=1730
            → 51px below ADD TO CART (1569+110=1679; 1730-1679=51). */}
        <p
          class="m-0 mt-[18px] sm:mt-[20px] md:mt-[25px] lg:mt-[29px] xl:mt-[36px]
                 text-black font-medium leading-[1]
                 text-[20px] sm:text-[26px] md:text-[34px] lg:text-[42px] xl:text-[52px]"
          data-node-id="3311:2224"
          data-price-display
          data-base-price={basePriceNumber}
        >{initialDisplayPrice}</p>
      </form>
    </div>
  </div>
</main>

<script>
  import {
    bindAddToCartSync,
    bindPriceDisplay,
    bindMessageFields,
    bindSelectionConstraints,
  } from "../../lib/snipcart/cartSync";

  document.addEventListener("astro:page-load", bindAddToCartSync);
  document.addEventListener("astro:page-load", bindPriceDisplay);
  document.addEventListener("astro:page-load", bindMessageFields);
  document.addEventListener("astro:page-load", bindSelectionConstraints);
</script>
