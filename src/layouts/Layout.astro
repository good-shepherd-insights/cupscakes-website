---
import { ClientRouter } from 'astro:transitions';
import Snipcart from '../components/snipcart/Snipcart.astro';
import CartButton from '../components/snipcart/CartButton.astro';

interface Props {
  title?: string;
}
const { title = 'Cupcakes' } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
      <CartButton />
    </nav>
    <main>
      <slot />
    </main>
    <Snipcart />
  </body>
</html>
