---
import { ClientRouter } from 'astro:transitions';
import { stegaClean } from '@sanity/client/stega';
import Snipcart from '../components/snipcart/Snipcart.astro';
import CartToast from '../components/snipcart/CartToast.astro';
import '../styles/global.css';
import '../styles/snipcart-overrides.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  canonicalUrl?: string;
}
const { title = 'Cupcakes', description, image, canonicalUrl } = Astro.props;
// Sanity's stega visual-editing encoding injects invisible Unicode into every
// GROQ string so the Presentation tool can map rendered text back to its
// source field. <title>/<meta> are never visible/clickable DOM, so the
// overlay can't attach there anyway — strip it here to avoid bloating the
// tab title and og/meta tags with thousands of invisible characters.
const cleanTitle = stegaClean(title);
const cleanDescription = description ? stegaClean(description) : undefined;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{cleanTitle}</title>
    {cleanDescription && <meta name="description" content={cleanDescription} />}
    {canonicalUrl && <link rel="canonical" href={canonicalUrl} />}
    <meta property="og:title" content={cleanTitle} />
    {cleanDescription && <meta property="og:description" content={cleanDescription} />}
    {image && <meta property="og:image" content={image} />}
    {canonicalUrl && <meta property="og:url" content={canonicalUrl} />}
    <meta name="twitter:card" content={image ? "summary_large_image" : "summary"} />
    {/* Jubilat font (matches the --font-sans token). */}
    <link rel="stylesheet" href="https://use.typekit.net/ezr1eax.css" />
    <link rel="icon" href="/assets/cups-icon.svg" type="image/svg+xml" />
    <ClientRouter />
    <Snipcart addProductBehavior="none" loadStrategy="manual" />
  </head>
  <body class="m-0 p-0 bg-white font-sans antialiased">
    <slot />
    <CartToast />
    {/* Snipcart's loader (lib/snipcart/loader.ts) reuses this div if it
        already exists rather than creating its own. transition:persist
        keeps this exact node alive across Astro ClientRouter navigations
        via Astro's native swap (see lib/snipcart/swapGuard.ts, which
        otherwise reuses Astro's own swap functions unmodified) — this
        div's handling was never the source of the double-add bug; see
        swapGuard.ts's header comment and
        specs/001-snipcart-double-add/research.md for what actually was. */}
    <div id="snipcart" hidden transition:persist></div>
    <script>
      import { installSnipcartSwapGuard } from "../lib/snipcart/swapGuard";
      installSnipcartSwapGuard();
    </script>
    <script>
      import { syncDraftToCart } from "../lib/snipcart/syncDraftToCart";
      document.addEventListener('snipcart.ready', () => {
        syncDraftToCart();
        document.addEventListener('snipcart.item.added', syncDraftToCart);
      });
      document.addEventListener('astro:page-load', () => {
        if ((window as unknown as { Snipcart?: { api?: { cart?: unknown } } }).Snipcart?.api?.cart) {
          syncDraftToCart();
        }
        const win = window as unknown as { LoadSnipcart?: () => void; __snipcartLoadTriggered?: boolean };
        if (!win.__snipcartLoadTriggered) {
          win.__snipcartLoadTriggered = true;
          win.LoadSnipcart?.();
        }
      });
    </script>
  </body>
</html>
