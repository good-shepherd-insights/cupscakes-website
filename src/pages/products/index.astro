---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/home/Navbar.astro";
import Footer from "../../components/home/Footer.astro";
import CategoryHeader from "../../components/product/CategoryHeader.astro";
import CupcakeGrid from "../../components/product/CupcakeGrid.astro";
import PersonalCakeGrid from "../../components/product/PersonalCakeGrid.astro";
import { loadHomeContent } from "../../lib/content/home";
import { loadProductsContent } from "../../lib/content/products";
import {
  getRequiredProductBySlug,
  getRequiredProductPriceBySlug,
} from "../../lib/sanity/queries/products";
import { resolveRequiredVariantImageUrls } from "../../lib/sanity/image";
import { IMAGE_WIDTHS } from "../../lib/constants";

const { navbar, footer, followUs } = await loadHomeContent();
const { categoryHeader, cupcakes, personalCakes } =
  await loadProductsContent();
const [cupcakeProduct, personalCakePrice] = await Promise.all([
  getRequiredProductBySlug("cupcakes"),
  getRequiredProductPriceBySlug("personal-cakes"),
]);
const cupcakeImages = resolveRequiredVariantImageUrls(cupcakeProduct, IMAGE_WIDTHS.card);
const cupcakeFlavors = cupcakes.flavors.map((flavor) => {
  const imageSrc = cupcakeImages.get(flavor.key);
  if (!imageSrc) {
    throw new Error(`Cupcake flavor "${flavor.key}" is missing its Sanity image.`);
  }
  return { ...flavor, imageSrc };
});
---
<Layout title="Cupcakes & Personal Cakes — Cups & Cakes">
  <div class="flex min-h-dvh flex-col">
    <Navbar {...navbar} mode="store" activeLink="products" facebookHref={followUs.facebookHref} instagramHref={followUs.instagramHref} />
    <CategoryHeader {...categoryHeader} />
    <CupcakeGrid {...cupcakes} flavors={cupcakeFlavors} price={cupcakeProduct.price} />
    <PersonalCakeGrid {...personalCakes} price={personalCakePrice} />
    <Footer {...footer} />
  </div>
</Layout>
